# ==========================================================
# Copy this file to .env and fill in real values.
# .env is read automatically by `docker compose` and by
# config/settings.py (via python-dotenv) for local runs too.
# NEVER commit the real .env file to git.
# ==========================================================

TELEGRAM_BOT_TOKEN=123456:ABC-your-real-telegram-bot-token
TELEGRAM_CHAT_ID=-1001234567890

# Leave blank unless you need MEXC private/authenticated endpoints
MEXC_API_KEY=
MEXC_API_SECRET=

# Supabase connection string (Project Settings -> Database -> Connection string)
SUPABASE_DB_DSN=postgresql://postgres:[email protected]:5432/postgres
